              "response": []
            },
            {
              "name": "GetBooking - 형식 오류 (4xx)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// ── 네거티브: 숫자가 아닌 잘못된 형식의 ID ──\r",
                      "\r",
                      "// 1. 잘못된 입력은 클라이언트 에러(4xx)여야 함\r",
                      "//    ※ restful-booker가 여기서 500을 뱉으면 → \"입력 검증 부재\" 버그\r",
                      "pm.test(\"잘못된 ID 형식은 클라이언트 에러(4xx)\", () => {\r",
                      "    pm.expect(pm.response.code).to.be.within(400, 499);\r",
                      "});\r",
                      "\r",
                      "// 2. 안전망: 서버 오류(5xx) 금지\r",
                      "pm.test(\"서버 오류(5xx)는 발생하지 않는다\", () => {\r",
                      "    pm.expect(pm.response.code).to.be.below(500);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/booking/invalid-id-format",
